# Salin file ini menjadi .env, lalu isi nilainya
# cp .env.example .env

PORT=5000

# Database MySQL
DB_HOST=localhost
DB_USER=nama_user_mysql
DB_PASS=password_mysql
DB_NAME=pengaduan_sarana_sekolah

# JWT Secret – ganti dengan string acak yang panjang dan aman
JWT_SECRET=ganti_dengan_secret_key_yang_kuat
